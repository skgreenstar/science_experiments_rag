FROM docker.elastic.co/elasticsearch/elasticsearch:8.17.0

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN curl -k -L -o /tmp/analysis-nori.zip \
    https://artifacts.elastic.co/downloads/elasticsearch-plugins/analysis-nori/analysis-nori-8.17.0.zip \
    && bin/elasticsearch-plugin install --batch file:///tmp/analysis-nori.zip \
    && rm -f /tmp/analysis-nori.zip

USER elasticsearch
