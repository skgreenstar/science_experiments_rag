# 인프라 연결
DATABASE_URL=postgresql+asyncpg://admin:changeme_strong_password@localhost:5432/shared
ELASTICSEARCH_URL=http://localhost:9200
OLLAMA_URL=http://localhost:11434
REDIS_URL=redis://localhost:6379
UPLOAD_MAX_MB=200

# RAG 모델 기본값 (환경변수 우선 적용)
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=bge-m3
RAG_EMBEDDING_DIMENSIONS=1024
RAG_LLM_PROVIDER=ollama
RAG_LLM_MODEL=exaone3.5:7.8b
RAG_LLM_TEMPERATURE=0.3
# 선택: 비어 있으면 RAG_LLM_MODEL 사용
RAG_HYDE_MODEL=
RAG_MULTI_QUERY_MODEL=
RAG_CONTEXTUAL_CHUNKING_MODEL=

# RAGAS 평가 모델 (선택)
RAGAS_LLM_PROVIDER=ollama
RAGAS_LLM_MODEL=exaone3.5:7.8b
RAGAS_EMBEDDING_PROVIDER=ollama
RAGAS_EMBEDDING_MODEL=bge-m3

# 외부 API 키 (선택)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse (선택)
# 로컬 uvicorn 실행 기준 (docker compose 내부에서는 http://langfuse-web:3000)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100
